---
import PrototypeDemo from "@/components/PrototypeDemo.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { caseStudyContent } from "@/content/caseStudy";
import { getPrimaryNav } from "@/content/navigation";
import { profileContent } from "@/content/profile";

const pageTitle = "Safety Intake Desk | BioScript Case-Study MVP";
const pageDescription =
  "A product-led GitHub Pages case study for a focused BioScript MVP: Safety Intake Desk.";
const baseUrl = import.meta.env.BASE_URL;
const nav = getPrimaryNav("demo", baseUrl);
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <SiteHeader nav={nav} />

  <main>
    <section class="hero-block section-block">
      <div class="page-shell hero-shell">
        <h1>{caseStudyContent.productName}</h1>
        <p class="hero-summary">
          Potential adverse events often surface inside routine patient-support interactions, where unstructured notes
          create missing minimum case facts and slow reviewer handoff. Safety Intake Desk fixes that first mile with
          guided capture, recoverable incomplete drafts, and a cleaner path to qualified PV review.
        </p>
      </div>
    </section>

    <div class="page-shell">
      <PrototypeDemo />
    </div>

    <section class="section-block">
      <div class="page-shell">
        <article class="panel note-panel">
          <h2>How this works</h2>
          <p>
            The workflow stays narrow on purpose: source notes, call transcripts, or emails enter first; a model builds
            an initial structured draft; reviewers focus on low-confidence fields; and complete, trusted cases exit as
            handoff-ready packets with visible status and audit context. The heavier rationale, delivery assumptions, and
            pilot notes live in the <a href={`${baseUrl}appendix/`}> appendix</a>.
          </p>
        </article>
      </div>
    </section>
  </main>

  <SiteFooter email={profileContent.contact.email} />
</BaseLayout>

<style>
  .hero-block {
    padding-top: 2.2rem;
  }

  .hero-shell {
    max-width: 60rem;
  }

  h1 {
    margin: 0;
    max-width: 11ch;
    font-size: clamp(3.8rem, 11vw, 8rem);
    line-height: 0.86;
    letter-spacing: -0.07em;
  }

  .hero-summary {
    margin: 1.25rem 0 0;
    max-width: 54rem;
    color: var(--color-text-soft);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .note-panel {
    padding: 1.5rem;
  }

  .note-panel h2 {
    margin: 0;
    font-size: clamp(1.5rem, 2.4vw, 2.1rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .note-panel p {
    margin: 0.9rem 0 0;
    max-width: 62rem;
    color: var(--color-text-soft);
    line-height: 1.8;
  }

  .note-panel a {
    color: var(--color-accent);
    font-weight: 600;
  }

  @media (max-width: 720px) {
    .hero-block {
      padding-top: 1.4rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(3rem, 16vw, 4.4rem);
    }
  }
</style>
