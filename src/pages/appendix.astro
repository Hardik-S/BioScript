---
import SectionHeading from "@/components/SectionHeading.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  appendixSections,
  demoAppendixSections,
  limitationSections,
  managerQuestions,
  riskRegister,
  shortVersionSections,
} from "@/content/appendix";
import { getPrimaryNav } from "@/content/navigation";

const title = "Safety Intake Desk Appendix";
const description = "Supporting notes for the BioScript Safety Intake Desk case study.";
const baseUrl = import.meta.env.BASE_URL;
const nav = getPrimaryNav("appendix", baseUrl);
const brand = {
  mark: "AP",
  title: "Appendix",
  subtitle: "BioScript case-study MVP",
};
---

<BaseLayout title={title} description={description} theme="appendix">
  <SiteHeader nav={nav} brand={brand} />

  <main id="top" class="section-block">
    <div class="page-shell appendix-shell">
      <SectionHeading
        eyebrow="Appendix"
        title="Supporting detail for all three demos"
        lead="Use this page as the evidence map: what each demo is trying to prove, when to show it, and how the pieces fit together without crowding the live workflows."
      />

      <section class="panel short-version-panel" aria-labelledby="short-version-title" data-short-version-panel>
        <div class="short-version-head">
          <div>
            <p class="section-kicker">Manager readout</p>
            <h2 id="short-version-title">Short version</h2>
          </div>
          <div class="short-version-tabs" role="tablist" aria-label="Short version demo selector">
            {shortVersionSections.map((section, index) => (
              <button
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`short-version-${section.id}`}
                class:list={[index === 0 && "is-active"]}
                data-short-version-button={section.id}
              >
                {section.navLabel}
              </button>
            ))}
          </div>
        </div>
        <div class="short-version-body">
          {shortVersionSections.map((section, index) => (
            <article
              id={`short-version-${section.id}`}
              class:list={["short-version-section", index !== 0 && "is-hidden"]}
              data-short-version-section={section.id}
              role="tabpanel"
            >
              <h3>{section.title}</h3>
              <p>{section.summary}</p>
              <ul>
                {section.points.map((point) => <li>{point}</li>)}
              </ul>
              <a class="cta-link secondary" href={section.href(baseUrl)}>{section.ctaLabel}</a>
            </article>
          ))}
        </div>
      </section>

      <nav class="demo-subnav panel" aria-label="Appendix demo sections">
        <span>Demo notes</span>
        <div>
          {demoAppendixSections.map((demo) => (
            <a href={`#demo-${demo.id}`}>{demo.navLabel}</a>
          ))}
        </div>
      </nav>

      <section class="demo-appendix-grid" aria-label="Demo appendix notes">
        {demoAppendixSections.map((demo) => (
          <article class="panel demo-appendix-card" id={`demo-${demo.id}`} data-demo-theme={demo.id}>
            <div class="demo-card-head">
              <p>{demo.routeLabel}</p>
              <h2>{demo.title}</h2>
            </div>
            <dl>
              <div>
                <dt>What it proves</dt>
                <dd>{demo.purpose}</dd>
              </div>
              <div>
                <dt>Use it when</dt>
                <dd>{demo.bestFor}</dd>
              </div>
            </dl>
            <ul>
              {demo.proofPoints.map((point) => <li>{point}</li>)}
            </ul>
            <a class="cta-link secondary" href={demo.href(baseUrl)}>Open {demo.navLabel}</a>
          </article>
        ))}
      </section>

      <div class="appendix-grid">
        {appendixSections.map((section) => (
          <article class="panel appendix-panel">
            <h2>{section.title}</h2>
            <p>{section.intro}</p>
            <ul>
              {section.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </div>

      <section class="panel manager-questions">
        <h2>Manager Questions Answered</h2>
        <div class="qa-grid">
          {managerQuestions.map((item) => (
            <article>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="limitation-grid" aria-label="Static demo limits and pilot controls">
        {limitationSections.map((section) => (
          <article class="panel appendix-panel">
            <h2>{section.title}</h2>
            <ul>
              {section.points.map((point) => <li>{point}</li>)}
            </ul>
          </article>
        ))}
      </section>

      <section class="panel risk-panel">
        <h2>Execution risks I would manage explicitly</h2>
        <div class="risk-grid">
          {riskRegister.map((item) => (
            <article>
              <h3>{item.title}</h3>
              <p>{item.mitigation}</p>
            </article>
          ))}
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<script is:inline>
  const shortVersionPanel = document.querySelector("[data-short-version-panel]");

  if (shortVersionPanel instanceof HTMLElement) {
    shortVersionPanel.classList.add("is-enhanced");
    const buttons = Array.from(shortVersionPanel.querySelectorAll("[data-short-version-button]"));
    const sections = Array.from(shortVersionPanel.querySelectorAll("[data-short-version-section]"));

    const activateSection = (id) => {
      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const isActive = button.dataset.shortVersionButton === id;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      sections.forEach((section) => {
        if (!(section instanceof HTMLElement)) return;
        section.classList.toggle("is-hidden", section.dataset.shortVersionSection !== id);
      });
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!(button instanceof HTMLButtonElement)) return;
        activateSection(button.dataset.shortVersionButton);
      });
    });
  }
</script>

<style>
  .appendix-shell {
    display: grid;
    gap: 1.2rem;
  }

  .short-version-panel {
    display: grid;
    gap: 1.2rem;
    padding: 1.5rem;
  }

  .short-version-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .section-kicker {
    margin: 0 0 0.35rem;
    color: var(--color-accent);
    font-family: var(--font-ui);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .short-version-tabs {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    justify-content: flex-end;
  }

  .short-version-tabs button {
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    background: transparent;
    color: var(--color-text-soft);
    cursor: pointer;
    font: 700 0.86rem/1 var(--font-ui);
    padding: 0.58rem 0.76rem;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .short-version-tabs button:hover,
  .short-version-tabs button:focus-visible,
  .short-version-tabs button.is-active {
    background: var(--color-accent);
    color: var(--color-inverse);
    transform: translateY(-1px);
  }

  .short-version-body {
    display: grid;
    gap: 1rem;
  }

  .short-version-panel.is-enhanced .short-version-section.is-hidden {
    display: none;
  }

  .short-version-section {
    display: grid;
    gap: 0.8rem;
  }

  .short-version-section h3 {
    margin: 0;
    font-size: clamp(1.35rem, 2.2vw, 1.9rem);
    line-height: 1.08;
  }

  .short-version-section p,
  .short-version-section li {
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  .short-version-section p,
  .short-version-section ul {
    margin: 0;
  }

  .short-version-section ul {
    display: grid;
    gap: 0.45rem;
    padding-left: 1.1rem;
  }

  .short-version-section .cta-link {
    justify-self: start;
    margin-top: 0.2rem;
  }

  .demo-subnav {
    position: sticky;
    top: 6.5rem;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
  }

  .demo-subnav span {
    color: var(--color-text-soft);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .demo-subnav div {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.55rem;
  }

  .demo-subnav a {
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-text-soft);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .demo-subnav a:hover,
  .demo-subnav a:focus-visible {
    background: var(--color-accent-soft);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  .demo-appendix-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    scroll-margin-top: 9rem;
  }

  .appendix-grid,
  .limitation-grid,
  .risk-grid {
    display: grid;
    gap: 1rem;
  }

  .appendix-grid,
  .limitation-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .appendix-panel,
  .demo-appendix-card,
  .manager-questions,
  .risk-panel {
    padding: 1.5rem;
  }

  .appendix-panel h2,
  .demo-appendix-card h2,
  .manager-questions h2,
  .risk-panel h2,
  .short-version-panel h2,
  .qa-grid h3,
  .risk-grid h3 {
    margin: 0;
  }

  .demo-card-head {
    display: grid;
    gap: 0.55rem;
  }

  .demo-appendix-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-color: color-mix(in srgb, var(--card-accent, var(--color-line-strong)) 24%, var(--color-line));
    background:
      linear-gradient(180deg, var(--card-accent-soft, transparent), transparent 42%),
      var(--panel-fill);
    scroll-margin-top: 9rem;
  }

  .demo-appendix-card[data-demo-theme="intake"] {
    --card-accent: #b55f2f;
    --card-accent-soft: rgba(181, 95, 47, 0.15);
  }

  .demo-appendix-card[data-demo-theme="reconciliation"] {
    --card-accent: #2f7380;
    --card-accent-soft: rgba(47, 115, 128, 0.15);
  }

  .demo-appendix-card[data-demo-theme="operations"] {
    --card-accent: #6b6741;
    --card-accent-soft: rgba(107, 103, 65, 0.16);
  }

  .demo-card-head p {
    margin: 0;
    color: var(--card-accent, var(--color-accent));
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .demo-appendix-card dl {
    display: grid;
    gap: 0.8rem;
    margin: 0;
  }

  .demo-appendix-card dt,
  .demo-appendix-card dd {
    margin: 0;
  }

  .demo-appendix-card dt {
    font-weight: 700;
  }

  .appendix-panel p,
  .appendix-panel li,
  .demo-appendix-card dd,
  .demo-appendix-card li,
  .manager-questions p,
  .risk-grid p {
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  .appendix-panel ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
  }

  .demo-appendix-card ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding-left: 1.1rem;
  }

  .demo-appendix-card .cta-link {
    align-self: flex-start;
    margin-top: auto;
  }

  .risk-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 1rem;
  }

  .qa-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  .qa-grid article {
    padding: 1rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--pill-fill);
  }

  .qa-grid h3 {
    font-size: 1rem;
    line-height: 1.25;
  }

  .risk-grid article {
    padding: 1rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(250, 245, 237, 0.65);
  }

  @media (max-width: 980px) {
    .demo-appendix-grid,
    .appendix-grid,
    .limitation-grid,
    .qa-grid,
    .risk-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .short-version-head {
      flex-direction: column;
    }

    .short-version-tabs {
      justify-content: flex-start;
    }

    .demo-subnav {
      position: static;
      align-items: flex-start;
      flex-direction: column;
    }

    .demo-subnav div {
      justify-content: flex-start;
    }
  }
</style>
