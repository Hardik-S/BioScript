---
interface Props {
  title: string;
  description: string;
  theme?: "intake" | "reconciliation" | "operations" | "appendix";
}

const { title, description, theme = "intake" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href={`${baseUrl}favicon.svg`} />
  </head>
  <body class={`theme-${theme}`}>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #f5efe4;
    --color-bg-strong: #ece4d5;
    --color-panel: rgba(15, 33, 30, 0.9);
    --color-panel-soft: rgba(247, 241, 230, 0.84);
    --color-line: rgba(17, 44, 40, 0.14);
    --color-line-strong: rgba(17, 44, 40, 0.32);
    --color-text: #16322f;
    --color-text-soft: rgba(22, 50, 47, 0.76);
    --color-inverse: #f6f0e4;
    --color-accent: #b55f2f;
    --color-accent-soft: rgba(181, 95, 47, 0.18);
    --color-mint: #2e635b;
    --color-shadow: 0 22px 60px rgba(28, 49, 45, 0.14);
    --font-body: Georgia, "Times New Roman", serif;
    --font-display: Georgia, "Times New Roman", serif;
    --font-ui: "Sora", "Trebuchet MS", "Segoe UI", sans-serif;
    --font-chrome: "Space Grotesk", "Avenir Next", "Segoe UI", sans-serif;
    --font-mono: "Courier New", Consolas, monospace;
    --theme-gradient-a: rgba(181, 95, 47, 0.16);
    --theme-gradient-b: rgba(46, 99, 91, 0.16);
    --theme-gradient-start: #f7f1e6;
    --theme-gradient-mid: #f2ebdf;
    --theme-gradient-end: #efe6d6;
    --panel-fill: rgba(250, 245, 237, 0.76);
    --pill-fill: rgba(250, 245, 237, 0.85);
    --page-max: 74rem;
    --radius-lg: 32px;
    --radius-md: 22px;
    --radius-sm: 14px;
    --space-section: clamp(4.5rem, 8vw, 8rem);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background:
      radial-gradient(circle at top left, var(--theme-gradient-a), transparent 34%),
      radial-gradient(circle at top right, var(--theme-gradient-b), transparent 36%),
      linear-gradient(180deg, var(--theme-gradient-start) 0%, var(--theme-gradient-mid) 52%, var(--theme-gradient-end) 100%);
    color: var(--color-text);
    font-family: var(--font-body);
    text-rendering: optimizeLegibility;
  }

  body.theme-reconciliation {
    --color-bg: #eef3ed;
    --color-bg-strong: #dde8e1;
    --color-panel: rgba(18, 47, 51, 0.9);
    --color-panel-soft: rgba(241, 247, 243, 0.86);
    --color-line: rgba(19, 61, 66, 0.16);
    --color-line-strong: rgba(19, 61, 66, 0.34);
    --color-text: #17383b;
    --color-text-soft: rgba(23, 56, 59, 0.74);
    --color-inverse: #f2f8f3;
    --color-accent: #2f7380;
    --color-accent-soft: rgba(47, 115, 128, 0.16);
    --color-mint: #356f61;
    --color-shadow: 0 22px 60px rgba(20, 54, 58, 0.13);
    --font-body: Cambria, Georgia, "Times New Roman", serif;
    --font-display: Cambria, Georgia, "Times New Roman", serif;
    --font-ui: "Segoe UI", "Aptos", Arial, sans-serif;
    --font-chrome: "Segoe UI", "Aptos", Arial, sans-serif;
    --font-mono: "Cascadia Mono", Consolas, "Courier New", monospace;
    --theme-gradient-a: rgba(47, 115, 128, 0.15);
    --theme-gradient-b: rgba(53, 111, 97, 0.14);
    --theme-gradient-start: #f3f7f2;
    --theme-gradient-mid: #eaf2ed;
    --theme-gradient-end: #e2ebe7;
    --panel-fill: rgba(247, 251, 248, 0.78);
    --pill-fill: rgba(247, 251, 248, 0.88);
  }

  body.theme-operations {
    --color-bg: #eff0e8;
    --color-bg-strong: #e3e4da;
    --color-panel: rgba(33, 42, 54, 0.9);
    --color-panel-soft: rgba(247, 247, 239, 0.86);
    --color-line: rgba(38, 49, 62, 0.16);
    --color-line-strong: rgba(38, 49, 62, 0.34);
    --color-text: #24313d;
    --color-text-soft: rgba(36, 49, 61, 0.74);
    --color-inverse: #f6f3e8;
    --color-accent: #6b6741;
    --color-accent-soft: rgba(107, 103, 65, 0.17);
    --color-mint: #4d7166;
    --color-shadow: 0 22px 60px rgba(33, 42, 54, 0.13);
    --font-body: "Segoe UI", "Aptos", Arial, sans-serif;
    --font-display: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
    --font-ui: "Segoe UI", "Aptos", Arial, sans-serif;
    --font-chrome: "Segoe UI", "Aptos", Arial, sans-serif;
    --font-mono: "Cascadia Mono", Consolas, "Courier New", monospace;
    --theme-gradient-a: rgba(107, 103, 65, 0.14);
    --theme-gradient-b: rgba(77, 113, 102, 0.14);
    --theme-gradient-start: #f4f3ea;
    --theme-gradient-mid: #ecede4;
    --theme-gradient-end: #e5e7dd;
    --panel-fill: rgba(249, 249, 241, 0.8);
    --pill-fill: rgba(249, 249, 241, 0.9);
  }

  body.theme-appendix {
    --font-body: Georgia, "Times New Roman", serif;
    --font-display: Georgia, "Times New Roman", serif;
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .page-shell {
    width: min(calc(100% - 2rem), var(--page-max));
    margin: 0 auto;
  }

  .section-block {
    padding: var(--space-section) 0;
  }

  .panel {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--panel-fill);
    box-shadow: var(--color-shadow);
    backdrop-filter: blur(12px);
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.72rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--pill-fill);
    font-size: 0.94rem;
    line-height: 1;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.92rem 1.2rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
  }

  .cta-link:hover,
  .cta-link:focus-visible {
    transform: translateY(-1px);
  }

  .cta-link.primary {
    background: var(--color-text);
    color: var(--color-inverse);
    border: 1px solid transparent;
  }

  .cta-link.secondary {
    background: transparent;
    border: 1px solid var(--color-line-strong);
  }

  @media (max-width: 720px) {
    .page-shell {
      width: min(calc(100% - 1.2rem), var(--page-max));
    }
  }
</style>
