---
import { prototypeContent } from "../data/prototype";

const stageOrder = prototypeContent.workflow.map((step) => step.id);
const intakeFieldOrder = prototypeContent.intakeFields.map((field) => field.id);
const extractionRuns = prototypeContent.extractionRuns;
---

<section class="prototype" id="prototype" aria-labelledby="prototype-title">
  <div class="shell">
    <header class="hero">
      <p class="kicker">Intake demo</p>
      <h2 id="prototype-title">{prototypeContent.title}</h2>
      <p class="subtitle">{prototypeContent.subtitle}</p>
    </header>

    <div class="layout">
      <aside class="rail" aria-label="Workflow stages">
        <ol>
          {
            prototypeContent.workflow.map((step, index) => (
              <li
                class:list={[
                  "step",
                  index === 0 && "is-active",
                  index === 0 && "is-complete",
                ]}
                data-step={step.id}
              >
                <h3>{step.label}</h3>
                <p>{step.note}</p>
              </li>
            ))
          }
        </ol>
      </aside>

      <div class="main">
        <section class="panel panel-context">
          <h3>Patient Context</h3>
          <div class="context-grid">
            {
              Object.entries(prototypeContent.patientContext).map(([key, value]) => (
                <div class="context-item">
                  <span>{key}</span>
                  <strong>{value}</strong>
                </div>
              ))
            }
          </div>
        </section>

        <section class="panel panel-intake" data-stage="intake">
          <div class="panel-head">
            <h3>Structured Intake Draft</h3>
            <p>
              Start with unstructured source material. The demo drafts intake fields from source text,
              and qualified reviewers confirm low-confidence or safety-relevant fields before handoff.
            </p>
          </div>

          <div class="raw-input-shell">
            <label class="raw-label" for="raw-intake-text">Raw intake note / call transcript / email text</label>
            <textarea
              id="raw-intake-text"
              rows={8}
              placeholder="Paste source material or run a sample extraction."
              spellcheck="false"
            ></textarea>
            <div class="raw-actions">
              <button type="button" class="run-button" data-action="run-extraction">Run extraction</button>
              <p id="source-status">Load a sample run to simulate deterministic extraction.</p>
            </div>
          </div>

          <form class="intake-form" id="prototype-intake-form" novalidate>
            <div class="panel-subhead">
              <h4>Extracted intake draft</h4>
              <p>Review draft data and confirm uncertain fields before handoff.</p>
            </div>
            {
              prototypeContent.intakeFields.map((field) => (
                <label class="field" data-field-id={field.id} for={field.id}>
                  <span class="field-head">
                    {field.label}
                    {field.required ? <em>Required</em> : <small>Optional</small>}
                  </span>
                  <div class="field-ai-meta" data-field-meta={field.id} hidden>
                    <span class="confidence-badge" data-confidence-badge={field.id}></span>
                    <p class="review-flag" data-review-flag={field.id}></p>
                  </div>
                  {field.id === "reactionSummary" || field.id === "notes" ? (
                    <textarea
                      id={field.id}
                      name={field.id}
                      required={field.required}
                      placeholder={field.placeholder}
                      rows={3}
                    >
                      {field.value}
                    </textarea>
                  ) : (
                    <input
                      id={field.id}
                      name={field.id}
                      required={field.required}
                      value={field.value}
                      placeholder={field.placeholder}
                    />
                  )}
                </label>
              ))
            }
            <div class="intake-status">
              <p id="required-populated-status">
                Required fields populated: 0 / {prototypeContent.requiredFields.length}
              </p>
              <p id="required-trusted-status">
                Required fields trusted for handoff: 0 / {prototypeContent.requiredFields.length}
              </p>
              <p id="draft-status">Draft has not been saved in this browser.</p>
            </div>
            <div class="actions">
              <button type="button" data-action="save">Save Incomplete</button>
              <button type="button" data-action="clear">Clear Draft</button>
              <button type="button" data-action="stage-handoff">Mark Handoff Ready</button>
            </div>
          </form>
        </section>

        <section class="panel minimum-criteria-panel" aria-labelledby="minimum-criteria-title">
          <div class="panel-subhead">
            <h3 id="minimum-criteria-title">Minimum Case Criteria</h3>
            <p>
              Day-0 clock is not treated as confirmed by this demo. PV owner confirms whether minimum criteria are met.
            </p>
          </div>
          <div class="criteria-table-wrap">
            <table class="criteria-table">
              <thead>
                <tr>
                  <th>Criterion</th>
                  <th>Source evidence</th>
                  <th>Confidence</th>
                  <th>Reviewer status</th>
                </tr>
              </thead>
              <tbody>
                {prototypeContent.minimumCaseCriteria.map((criterion) => (
                  <tr>
                    <td>{criterion.criterion}</td>
                    <td>{criterion.sourceEvidence}</td>
                    <td><span class={`confidence-badge ${criterion.confidence}`}>{criterion.confidence}</span></td>
                    <td>{criterion.reviewerStatus}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <section class="panel stage-panel" data-stage="saved">
          <h3>Saved Incomplete State</h3>
          <p>
            Case is retained with timestamp, missing fields, and routed to reviewer queue with
            "follow-up needed" status. PV owner confirms validity, seriousness, duplicate status, and reportability.
          </p>
          <ul class="pills">
            <li>Case: AE-2026-0431</li>
            <li>State: Draft preserved</li>
            <li>Missing items flagged for reviewer</li>
          </ul>
        </section>

        <section class="panel stage-panel" data-stage="queue">
          <h3>Reviewer Queue</h3>
          <table>
            <thead>
              <tr>
                <th>Case</th>
                <th>Patient</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Submitted</th>
              </tr>
            </thead>
            <tbody>
              {
                prototypeContent.queue.map((row) => (
                  <tr>
                    <td>{row.caseId}</td>
                    <td>{row.patient}</td>
                    <td><span class={`priority ${row.priority.toLowerCase()}`}>{row.priority}</span></td>
                    <td>{row.status}</td>
                    <td>{row.submittedAt}</td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </section>

        <section class="panel stage-panel" data-stage="followup">
          <h3>Follow-up State</h3>
          <ul class="task-list">
            {
              prototypeContent.followUp.map((task) => (
                <li>
                  <div>
                    <strong>{task.task}</strong>
                    <p>{task.owner}</p>
                  </div>
                  <div>
                    <span>{task.due}</span>
                    <em>{task.status}</em>
                  </div>
                </li>
              ))
            }
          </ul>
        </section>

        <section class="panel stage-panel" data-stage="handoff">
          <h3>Handoff-Ready / Export</h3>
          <p>
            Packet <strong>{prototypeContent.handoff.packetId}</strong> is prepared for
            <strong> {prototypeContent.handoff.destination}</strong>.
          </p>
          <ul>
            {prototypeContent.handoff.included.map((item) => <li>{item}</li>)}
          </ul>
          <p class="export-state">{prototypeContent.handoff.exportState}</p>
        </section>

        <section class="panel stage-panel" data-stage="audit">
          <h3>Audit / KPI Snapshot</h3>
          <div class="metrics">
            {
              prototypeContent.metrics.map((metric) => (
                <article>
                  <h4>{metric.label}</h4>
                  <p>{metric.value}</p>
                  <small>{metric.delta}</small>
                </article>
              ))
            }
          </div>
        </section>

        <section class="stage-controls" aria-label="Workflow views">
          <p class="view-label">Open another workflow view</p>
          {
            prototypeContent.workflow.map((step) => (
              <button
                type="button"
                data-stage-target={step.id}
                class="stage-button"
              >
                {step.label}
              </button>
            ))
          }
        </section>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ stageOrder, intakeFieldOrder, extractionRuns }}>
  const STORAGE_KEY = "bioscript-prototype-draft-v1";
  const root = document.getElementById("prototype");

  if (root) {
    let restoredDraft = false;
    let extractionIndex = 0;
    let hasRun = false;
    let isAnimating = false;
    let animationToken = 0;
    let activeRun = null;
    let userTriggeredRun = false;
    let autoRunTimeoutId = null;

    const modelFieldState = new Map();
    const form = root.querySelector("#prototype-intake-form");
    const rawInput = root.querySelector("#raw-intake-text");
    const runButton = root.querySelector('[data-action="run-extraction"]');
    const sourceStatus = root.querySelector("#source-status");
    const requiredPopulatedStatus = root.querySelector("#required-populated-status");
    const requiredTrustedStatus = root.querySelector("#required-trusted-status");
    const draftStatus = root.querySelector("#draft-status");
    const stageButtons = root.querySelectorAll("[data-stage-target]");
    const stagePanels = root.querySelectorAll(".stage-panel");
    const railSteps = root.querySelectorAll(".step");
    const inputs = form ? form.querySelectorAll("input, textarea") : [];

    const wait = (ms) => new Promise((resolve) => window.setTimeout(resolve, ms));
    const asField = (field) =>
      field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement ? field : null;

    const getRequiredCounts = () => {
      if (!form) return { populated: 0, trusted: 0, total: 0 };
      const required = [...form.querySelectorAll("[required]")].filter((field) => asField(field));
      let populated = 0;
      let trusted = 0;
      required.forEach((field) => {
        const value = field.value.trim();
        if (!value) return;
        populated += 1;
        const meta = modelFieldState.get(field.name);
        const fieldTrusted = !meta || meta.confidence !== "low" || meta.confirmed;
        if (fieldTrusted) trusted += 1;
      });
      return { populated, trusted, total: required.length };
    };

    const setStage = (stageId) => {
      stagePanels.forEach((panel) => {
        panel.classList.toggle("is-visible", panel.dataset.stage === stageId);
      });
      stageButtons.forEach((button) => {
        button.classList.toggle("is-active", button.dataset.stageTarget === stageId);
      });
      railSteps.forEach((step, index) => {
        const targetIndex = stageOrder.indexOf(stageId);
        const stepIndex = stageOrder.indexOf(step.dataset.step || "");
        step.classList.toggle("is-active", step.dataset.step === stageId);
        step.classList.toggle("is-complete", stepIndex >= 0 && stepIndex <= targetIndex);
        if (index === 0 && stageId !== "intake") {
          step.classList.add("is-complete");
        }
      });
    };

    const updateRunButtonState = () => {
      if (!(runButton instanceof HTMLButtonElement)) return;
      if (isAnimating) {
        runButton.textContent = "Skip animation";
        runButton.setAttribute("aria-busy", "true");
      } else {
        runButton.textContent = hasRun ? "Run again" : "Run extraction";
        runButton.removeAttribute("aria-busy");
      }
    };

    const clearAutoRunTimeout = () => {
      if (autoRunTimeoutId !== null) {
        window.clearTimeout(autoRunTimeoutId);
        autoRunTimeoutId = null;
      }
    };

    const scheduleAutoRun = () => {
      clearAutoRunTimeout();
      autoRunTimeoutId = window.setTimeout(() => {
        if (userTriggeredRun || hasRun || isAnimating) return;
        if (sourceStatus) {
          sourceStatus.textContent = "No manual run detected. Auto-running a sample extraction.";
        }
        void runExtraction();
      }, 30000);
    };

    const setFieldValue = (fieldId, value) => {
      if (!form) return;
      const field = asField(form.elements.namedItem(fieldId));
      if (field) field.value = value;
    };

    const clearFieldMeta = (fieldId, wrapper, metaBlock) => {
      wrapper.classList.remove("is-low-confidence", "is-reviewed-confidence");
      if (metaBlock instanceof HTMLElement) {
        const badge = metaBlock.querySelector("[data-confidence-badge]");
        const note = metaBlock.querySelector("[data-review-flag]");
        if (badge instanceof HTMLElement) {
          badge.textContent = "";
          badge.classList.remove("high", "medium", "low");
        }
        if (note instanceof HTMLElement) note.textContent = "";
        metaBlock.hidden = true;
      }
      modelFieldState.delete(fieldId);
    };

    const renderFieldMeta = (fieldId) => {
      const wrapper = root.querySelector(`[data-field-id="${fieldId}"]`);
      const metaBlock = root.querySelector(`[data-field-meta="${fieldId}"]`);
      if (!(wrapper instanceof HTMLElement)) return;
      const meta = modelFieldState.get(fieldId);
      if (!meta) {
        clearFieldMeta(fieldId, wrapper, metaBlock);
        return;
      }

      const needsReview = meta.confidence === "low" && !meta.confirmed;
      const reviewed = meta.confidence === "low" && meta.confirmed;
      wrapper.classList.toggle("is-low-confidence", needsReview);
      wrapper.classList.toggle("is-reviewed-confidence", reviewed);
      if (!(metaBlock instanceof HTMLElement)) return;

      const badge = metaBlock.querySelector("[data-confidence-badge]");
      const note = metaBlock.querySelector("[data-review-flag]");
      const confText = `${meta.confidence[0].toUpperCase()}${meta.confidence.slice(1)}`;
      if (badge instanceof HTMLElement) {
        badge.textContent = `Confidence: ${confText}`;
        badge.classList.remove("high", "medium", "low");
        badge.classList.add(meta.confidence);
      }
      if (note instanceof HTMLElement) {
        if (meta.confidence === "low") {
          const prefix = meta.confirmed ? "Reviewer confirmed." : "Needs reviewer confirmation.";
          note.textContent = meta.reviewNote ? `${prefix} ${meta.reviewNote}` : prefix;
        } else {
          note.textContent = meta.reviewNote || "Model-populated field.";
        }
      }
      metaBlock.hidden = false;
    };

    const renderAllFieldMeta = () => {
      intakeFieldOrder.forEach((fieldId) => renderFieldMeta(fieldId));
    };

    const updateRequiredStatus = () => {
      const counts = getRequiredCounts();
      if (requiredPopulatedStatus) {
        requiredPopulatedStatus.textContent =
          `Required fields populated: ${counts.populated} / ${counts.total}`;
      }
      if (requiredTrustedStatus) {
        requiredTrustedStatus.textContent =
          `Required fields trusted for handoff: ${counts.trusted} / ${counts.total}`;
      }
      return counts;
    };

    const applyRun = (run) => {
      if (rawInput instanceof HTMLTextAreaElement) rawInput.value = run.rawText;
      intakeFieldOrder.forEach((fieldId) => {
        setFieldValue(fieldId, run.extractedValues[fieldId] || "");
        const confidence = run.fieldConfidence[fieldId];
        if (confidence) {
          modelFieldState.set(fieldId, {
            confidence,
            reviewNote: run.reviewFlags?.[fieldId] || "",
            confirmed: false,
          });
        } else {
          modelFieldState.delete(fieldId);
        }
        renderFieldMeta(fieldId);
      });
      updateRequiredStatus();
    };

    const finalizeRun = (wasSkipped) => {
      isAnimating = false;
      hasRun = true;
      activeRun = null;
      updateRunButtonState();
      updateRequiredStatus();
      setStage("intake");
      if (sourceStatus) {
        sourceStatus.textContent = wasSkipped
          ? "Extraction finalized. Review low-confidence fields before handoff."
          : "Extraction draft ready. Review low-confidence fields before handoff.";
      }
      if (draftStatus) {
        draftStatus.textContent =
          "Model-built draft loaded. Save Incomplete to persist this draft locally.";
      }
    };

    const typeRawText = async (text, token) => {
      if (!(rawInput instanceof HTMLTextAreaElement)) return;
      const chunkSize = 3;
      for (let index = 0; index < text.length; index += chunkSize) {
        if (token !== animationToken) return;
        rawInput.value = text.slice(0, index + chunkSize);
        await wait(8);
      }
      rawInput.value = text;
    };

    const fillFields = async (run, token) => {
      for (const fieldId of intakeFieldOrder) {
        if (token !== animationToken) return;
        setFieldValue(fieldId, run.extractedValues[fieldId] || "");
        const confidence = run.fieldConfidence[fieldId];
        if (confidence) {
          modelFieldState.set(fieldId, {
            confidence,
            reviewNote: run.reviewFlags?.[fieldId] || "",
            confirmed: false,
          });
        } else {
          modelFieldState.delete(fieldId);
        }
        renderFieldMeta(fieldId);
        updateRequiredStatus();
        await wait(150);
      }
    };

    const runExtraction = async () => {
      if (isAnimating || !form || extractionRuns.length === 0) return;
      const run = extractionRuns[extractionIndex % extractionRuns.length];
      extractionIndex = (extractionIndex + 1) % extractionRuns.length;
      activeRun = run;
      animationToken += 1;
      const token = animationToken;
      isAnimating = true;
      updateRunButtonState();
      setStage("intake");

      modelFieldState.clear();
      intakeFieldOrder.forEach((fieldId) => {
        setFieldValue(fieldId, "");
        renderFieldMeta(fieldId);
      });
      if (rawInput instanceof HTMLTextAreaElement) rawInput.value = "";
      updateRequiredStatus();

      if (sourceStatus) sourceStatus.textContent = "Typing source text...";
      if (draftStatus) draftStatus.textContent = "Building extracted intake draft...";

      await typeRawText(run.rawText, token);
      if (token !== animationToken) return;
      if (sourceStatus) sourceStatus.textContent = "Mapping extracted fields...";
      await fillFields(run, token);
      if (token !== animationToken) return;
      finalizeRun(false);
    };

    const skipExtraction = () => {
      if (!isAnimating || !activeRun) return;
      animationToken += 1;
      applyRun(activeRun);
      finalizeRun(true);
    };

    const saveDraft = () => {
      if (!form) return;
      const payload = {
        savedAt: new Date().toLocaleString(),
        values: Object.fromEntries(new FormData(form).entries()),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(payload));
      if (draftStatus) {
        draftStatus.textContent = `Draft saved locally at ${payload.savedAt}.`;
      }
      setStage("saved");
    };

    const loadDraft = () => {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw || !form) return;
      try {
        const parsed = JSON.parse(raw);
        restoredDraft = true;
        Object.entries(parsed.values || {}).forEach(([name, value]) => {
          const field = asField(form.elements.namedItem(name));
          if (field) field.value = String(value ?? "");
        });
        if (draftStatus && parsed.savedAt) {
          draftStatus.textContent = `Draft restored from ${parsed.savedAt}.`;
        }
      } catch (_err) {
        localStorage.removeItem(STORAGE_KEY);
      }
    };

    const clearDraft = () => {
      animationToken += 1;
      isAnimating = false;
      activeRun = null;
      hasRun = false;
      updateRunButtonState();
      localStorage.removeItem(STORAGE_KEY);
      if (!form) return;
      inputs.forEach((input) => {
        input.value = input.defaultValue || "";
      });
      modelFieldState.clear();
      renderAllFieldMeta();
      if (rawInput instanceof HTMLTextAreaElement) rawInput.value = "";
      if (sourceStatus) {
        sourceStatus.textContent = "Load a sample run to simulate deterministic extraction.";
      }
      if (draftStatus) {
        draftStatus.textContent = "Draft cleared from this browser.";
      }
      updateRequiredStatus();
      setStage("intake");
    };

    root.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const action = target.dataset.action;
      if (action === "run-extraction") {
        userTriggeredRun = true;
        clearAutoRunTimeout();
        if (isAnimating) {
          skipExtraction();
        } else {
          void runExtraction();
        }
      } else if (action === "save") {
        saveDraft();
      } else if (action === "clear") {
        clearDraft();
      } else if (action === "stage-handoff") {
        const counts = updateRequiredStatus();
        if (counts.populated === counts.total && counts.trusted === counts.total) {
          setStage("handoff");
          if (draftStatus) {
            draftStatus.textContent = "Required data complete and trusted. Case marked handoff-ready.";
          }
        } else if (draftStatus) {
          draftStatus.textContent = counts.populated < counts.total
            ? "Complete all required fields before handoff-ready state."
            : "Confirm low-confidence required fields before handoff-ready state.";
        }
      }

      if (target.dataset.stageTarget) {
        setStage(target.dataset.stageTarget);
      }
    });

    inputs.forEach((field) => {
      field.addEventListener("input", () => {
        const meta = modelFieldState.get(field.name);
        if (meta && meta.confidence === "low" && !meta.confirmed) {
          meta.confirmed = true;
          modelFieldState.set(field.name, meta);
          renderFieldMeta(field.name);
        }
        updateRequiredStatus();
      });
    });

    loadDraft();
    renderAllFieldMeta();
    updateRequiredStatus();
    updateRunButtonState();
    setStage(restoredDraft ? "saved" : "intake");
    scheduleAutoRun();
  }
</script>

<style>
  .prototype {
    --bg: #f3efe8;
    --ink: #1e1b18;
    --ink-muted: #4f4a43;
    --surface: #fffdfa;
    --surface-2: #f9f4ec;
    --accent: #8a3b12;
    --accent-soft: #e9c6a3;
    --line: #d4c5b5;
    --high: #b32020;
    --med: #95600b;
    --low: #286236;
    color: var(--ink);
    margin: 4rem 0;
    font-family: var(--font-chrome);
  }

  .shell {
    background: radial-gradient(120% 120% at 95% 0%, #f3dcbc 0%, var(--bg) 52%);
    border: 1px solid var(--line);
    border-radius: 1.2rem;
    box-shadow: 0 30px 60px rgba(58, 37, 20, 0.12);
    overflow: hidden;
  }

  .hero {
    border-bottom: 1px solid var(--line);
    padding: 2rem 2.2rem 1.8rem;
    background: linear-gradient(110deg, #fff7ef 0%, #f9f1e7 60%, #f2e9de 100%);
  }

  .kicker {
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--accent);
    margin: 0 0 0.35rem;
    font-weight: 700;
  }

  .hero h2 {
    margin: 0;
    font-size: clamp(1.6rem, 2.6vw, 2.3rem);
    font-family: var(--font-ui);
    line-height: 1.15;
  }

  .subtitle {
    margin: 0.6rem 0 0;
    color: var(--ink-muted);
    max-width: 64ch;
  }

  .layout {
    display: grid;
    grid-template-columns: minmax(12rem, 17rem) minmax(0, 1fr);
    min-height: 42rem;
  }

  .rail {
    background: linear-gradient(180deg, #26221f 0%, #1b1917 100%);
    color: #f5eee5;
    padding: 1.2rem 1rem;
    border-right: 1px solid #4e4338;
  }

  .rail ol {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .step {
    padding: 0.8rem;
    border: 1px solid #4e4338;
    border-radius: 0.65rem;
    background: rgba(255, 255, 255, 0.03);
    transition: transform 180ms ease, background-color 180ms ease;
  }

  .step h3 {
    margin: 0 0 0.35rem;
    font-size: 0.9rem;
  }

  .step p {
    margin: 0;
    font-size: 0.8rem;
    color: #d8c9bb;
  }

  .step.is-complete {
    border-color: #9a7f5d;
    background: rgba(154, 127, 93, 0.22);
  }

  .step.is-active {
    background: rgba(212, 177, 139, 0.27);
    transform: translateX(3px);
  }

  .main {
    background: var(--surface);
    padding: 1.1rem;
    display: grid;
    gap: 0.95rem;
  }

  .panel {
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    background: linear-gradient(180deg, #fffdfa 0%, #fbf6ef 100%);
    padding: 1rem;
  }

  .panel h3 {
    margin: 0 0 0.45rem;
    font-size: 1rem;
    font-family: var(--font-ui);
  }

  .panel p {
    margin: 0.25rem 0;
    color: var(--ink-muted);
  }

  .context-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem;
  }

  .context-item {
    background: var(--surface-2);
