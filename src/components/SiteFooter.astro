---
interface Props {
  email: string;
}

const { email } = Astro.props;
---

<footer class="site-footer section-block">
  <div class="page-shell footer-shell panel">
    <div>
      <p class="eyebrow">Next Step</p>
      <h2>Pressure-test the workflow against a real PV intake path.</h2>
      <p>
        The prototype is deliberately narrow: first-mile capture, reviewer queueing, follow-up, and handoff readiness.
        If that wedge is worth discussing, email Hardik.
      </p>
    </div>
    <div class="footer-links">
      <a class="cta-link primary" href={`mailto:${email}?subject=Safety Intake Desk case study`}>
        Email Hardik
      </a>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    display: grid;
    grid-template-columns: 1.7fr 1fr;
    gap: 2rem;
    padding: 2rem;
  }

  .eyebrow,
  h2,
  p {
    margin: 0;
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  h2 {
    margin-top: 0.65rem;
    font-size: clamp(1.8rem, 2.4vw, 2.8rem);
    line-height: 1;
    letter-spacing: -0.04em;
  }

  p {
    margin-top: 1rem;
    max-width: 44rem;
    color: var(--color-text-soft);
    line-height: 1.75;
  }

  .footer-links {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: center;
    gap: 0.8rem;
  }

  @media (max-width: 820px) {
    .footer-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
