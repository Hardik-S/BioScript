---
import { reconciliationRecords, reconciliationSummary } from "@/data/reconciliation";

const flaggedRecords = reconciliationRecords.filter((record) => record.status !== "Clean");
const sourceRows = reconciliationRecords.map((record) => ({
  caseId: record.caseId,
  primary: record.channel,
  secondary: `${record.patientToken} - ${record.eventPhrase}`,
  meta: record.sourceReceivedAt,
  status: record.status,
}));
const transferRows = reconciliationRecords.map((record) => ({
  caseId: record.caseId,
  primary: record.transferredAt,
  secondary: `${record.suspectProduct} to external safety mailbox`,
  meta: record.reporter,
  status: record.status,
}));
const acknowledgementRows = reconciliationRecords.map((record) => ({
  caseId: record.caseId,
  primary: record.acknowledgementStatus,
  secondary: record.acknowledgementReason,
  meta: record.acknowledgementAt,
  status: record.status,
}));
const clientRecords = reconciliationRecords.map((record) => ({
  caseId: record.caseId,
  status: record.status,
  severity: record.severity,
  finding: record.finding,
  sourceSnippet: record.sourceSnippet,
  dayZeroImplication: record.dayZeroImplication,
  escalationSummary: record.escalationSummary,
  sourceReceivedAt: record.sourceReceivedAt,
  transferredAt: record.transferredAt,
  acknowledgementAt: record.acknowledgementAt,
  acknowledgementStatus: record.acknowledgementStatus,
}));
---

<section class="reconciliation" id="reconciliation-drill" aria-labelledby="reconciliation-title">
  <div class="drill-hero">
    <p class="kicker">Reconciliation demo</p>
    <div>
      <h1 id="reconciliation-title">{reconciliationSummary.title}</h1>
      <p>{reconciliationSummary.subtitle}</p>
    </div>
    <a class="home-link" href={import.meta.env.BASE_URL}>Intake demo</a>
  </div>

  <div class="control-bar panel">
    <div>
      <strong>Control objective</strong>
      <p>Compare exported PSP source records, transfer evidence, and external safety-system acknowledgements.</p>
    </div>
    <button type="button" class="run-control" data-action="run-control">Run Control</button>
  </div>

  <p class="control-status" data-control-status>
    Control has not run yet. The ledgers below are synthetic and static.
  </p>

  <section class="ledger-shell" data-ledger-shell aria-labelledby="ledger-shell-title">
    <div class="ledger-summary-bar panel">
      <div>
        <p class="kicker">Ledger selector</p>
        <h2 id="ledger-shell-title">Choose the record to inspect.</h2>
        <p data-ledger-summary>Select a row from any ledger to focus the evidence view.</p>
      </div>
      <button
        type="button"
        class="change-selection"
        data-action="toggle-ledgers"
        aria-controls="ledger-choice-panel"
        aria-expanded="true"
      >
        Collapse choices
      </button>
    </div>

    <div class="ledger-body" id="ledger-choice-panel" data-ledger-body>
      <div class="ledger-grid" aria-label="Reconciliation ledgers">
        <section class="ledger panel" aria-labelledby="source-ledger-title">
          <div class="ledger-head">
            <span>01</span>
            <h2 id="source-ledger-title">PSP source log</h2>
          </div>
          <div class="ledger-list">
            {sourceRows.map((row) => (
              <button
                type="button"
                class:list={["ledger-row", row.status !== "Clean" && "has-finding"]}
                data-record-row={row.caseId}
                data-status={row.status}
              >
                <div class="row-top">
                  <span class="record-id">{row.caseId}</span>
                  <b class="selected-chip" data-selected-chip hidden>Selected</b>
                </div>
                <strong>{row.primary}</strong>
                <small>{row.secondary}</small>
                <em>{row.meta}</em>
              </button>
            ))}
          </div>
        </section>

        <section class="ledger panel" aria-labelledby="transfer-ledger-title">
          <div class="ledger-head">
            <span>02</span>
            <h2 id="transfer-ledger-title">Safety transfer ledger</h2>
          </div>
          <div class="ledger-list">
            {transferRows.map((row) => (
              <button
                type="button"
                class:list={["ledger-row", row.status !== "Clean" && "has-finding"]}
                data-record-row={row.caseId}
                data-status={row.status}
              >
                <div class="row-top">
                  <span class="record-id">{row.caseId}</span>
                  <b class="selected-chip" data-selected-chip hidden>Selected</b>
                </div>
                <strong>{row.primary}</strong>
                <small>{row.secondary}</small>
                <em>{row.meta}</em>
              </button>
            ))}
          </div>
        </section>

        <section class="ledger panel" aria-labelledby="ack-ledger-title">
          <div class="ledger-head">
            <span>03</span>
            <h2 id="ack-ledger-title">Acknowledgement ledger</h2>
          </div>
          <div class="ledger-list">
            {acknowledgementRows.map((row) => (
              <button
                type="button"
                class:list={["ledger-row", row.status !== "Clean" && "has-finding"]}
                data-record-row={row.caseId}
                data-status={row.status}
              >
                <div class="row-top">
                  <span class="record-id">{row.caseId}</span>
                  <b class="selected-chip" data-selected-chip hidden>Selected</b>
                </div>
                <strong>{row.primary}</strong>
                <small>{row.secondary}</small>
                <em>{row.meta}</em>
              </button>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="selected-record panel" data-selected-record aria-live="polite" aria-labelledby="selected-record-title">
    <div class="panel-title">
      <p class="kicker">Selected record</p>
      <h2 id="selected-record-title">Ledger selection preview</h2>
    </div>

    <div class="evidence-head">
      <div>
        <span data-selected-case>No record selected</span>
        <h3 data-selected-finding>Run the control or select a ledger row to inspect source evidence.</h3>
      </div>
      <strong data-selected-status>Waiting</strong>
    </div>

    <div class="timestamp-grid">
      <div>
        <span>Source receipt</span>
        <strong data-selected-source>--</strong>
      </div>
      <div>
        <span>PSP transfer</span>
        <strong data-selected-transfer>--</strong>
      </div>
      <div>
        <span>Acknowledgement</span>
        <strong data-selected-acknowledgement>--</strong>
      </div>
    </div>

    <blockquote data-selected-snippet>
      Select any row in the three ledgers to keep the source, transfer, acknowledgement, and evidence view in sync.
    </blockquote>

    <p class="day-zero" data-selected-note>
      The preview updates immediately, before the longer control-output section below.
    </p>
  </section>

  <div class="analysis-grid" data-analysis hidden>
    <section class="findings panel" aria-labelledby="findings-title">
      <div class="panel-title">
        <p class="kicker">Control output</p>
        <h2 id="findings-title">Mismatches to review</h2>
      </div>
      <div class="finding-list">
        {flaggedRecords.map((record, index) => (
          <button
            type="button"
            class:list={["finding-card", index === 0 && "is-active"]}
            data-finding={record.caseId}
          >
            <div class="row-top">
              <span class="record-id">{record.status}</span>
              <b class="selected-chip" data-selected-chip hidden>Selected</b>
            </div>
            <strong>{record.caseId}</strong>
            <small>{record.finding}</small>
          </button>
        ))}
      </div>
    </section>

    <section class="evidence panel" aria-live="polite" aria-labelledby="evidence-title">
      <div class="panel-title">
        <p class="kicker">Evidence view</p>
        <h2 id="evidence-title">Source-backed issue detail</h2>
      </div>

      {reconciliationRecords.map((record) => (
        <article class:list={["evidence-record", record.caseId !== flaggedRecords[0]?.caseId && "is-hidden"]} data-detail={record.caseId}>
          <div class="evidence-head">
            <div>
              <span>{record.caseId}</span>
              <h3>{record.finding}</h3>
            </div>
            <strong>{record.severity}</strong>
          </div>

          <div class="timestamp-grid">
            <div>
              <span>Source receipt</span>
              <strong>{record.sourceReceivedAt}</strong>
            </div>
            <div>
              <span>PSP transfer</span>
              <strong>{record.transferredAt}</strong>
            </div>
            <div>
              <span>Acknowledgement</span>
              <strong>{record.acknowledgementAt}</strong>
            </div>
          </div>

          <blockquote>{record.sourceSnippet}</blockquote>

          <div class="criteria-grid">
            {record.minimumCriteria.map((criterion) => (
              <div class={`criterion ${criterion.state}`}>
                <span>{criterion.label}</span>
                <strong>{criterion.state}</strong>
                <small>{criterion.evidence}</small>
              </div>
            ))}
          </div>

          <p class="day-zero"><strong>Day 0 note:</strong> {record.dayZeroImplication}</p>
          {record.status === "Clean" && (
            <p class="clean-note">
              This row reconciles cleanly. Keep it visible for comparison, but do not prepare an escalation packet.
            </p>
          )}
        </article>
      ))}

      <button type="button" class="packet-button" data-action="prepare-packet">
        Prepare PV Escalation Packet
      </button>
    </section>
  </div>

  <section class="packet panel" data-packet hidden aria-live="polite">
    <div class="panel-title">
      <p class="kicker">Static evidence note</p>
      <h2>PV escalation packet preview</h2>
    </div>
    <pre data-packet-output></pre>
    <p>{reconciliationSummary.guardrail}</p>
  </section>

  <aside class="guardrail">
    <strong>Human-control boundary</strong>
    <span>{reconciliationSummary.guardrail}</span>
  </aside>
</section>

<script is:inline define:vars={{ clientRecords }}>
  const root = document.getElementById("reconciliation-drill");

  if (root) {
    const records = new Map(clientRecords.map((record) => [record.caseId, record]));
    const runButton = root.querySelector('[data-action="run-control"]');
    const packetButton = root.querySelector('[data-action="prepare-packet"]');
    const status = root.querySelector("[data-control-status]");
    const analysis = root.querySelector("[data-analysis]");
    const packet = root.querySelector("[data-packet]");
    const packetOutput = root.querySelector("[data-packet-output]");
    const ledgerShell = root.querySelector("[data-ledger-shell]");
    const ledgerBody = root.querySelector("[data-ledger-body]");
    const ledgerToggle = root.querySelector('[data-action="toggle-ledgers"]');
    const ledgerSummary = root.querySelector("[data-ledger-summary]");
    const selectedCase = root.querySelector("[data-selected-case]");
    const selectedFinding = root.querySelector("[data-selected-finding]");
    const selectedStatus = root.querySelector("[data-selected-status]");
    const selectedSource = root.querySelector("[data-selected-source]");
    const selectedTransfer = root.querySelector("[data-selected-transfer]");
    const selectedAcknowledgement = root.querySelector("[data-selected-acknowledgement]");
    const selectedSnippet = root.querySelector("[data-selected-snippet]");
    const selectedNote = root.querySelector("[data-selected-note]");
    const firstRecord = clientRecords.find((record) => record.status !== "Clean")?.caseId || clientRecords[0]?.caseId;
    const issueCount = clientRecords.filter((record) => record.status !== "Clean").length;
    let controlHasRun = false;
    let activeRecordId = firstRecord;

    function setLedgerCollapsed(isCollapsed) {
      if (ledgerShell) {
        ledgerShell.classList.toggle("is-collapsed", isCollapsed);
      }
      if (ledgerBody instanceof HTMLElement) {
        ledgerBody.setAttribute("aria-hidden", isCollapsed ? "true" : "false");
      }
      if (ledgerToggle instanceof HTMLButtonElement) {
        ledgerToggle.textContent = isCollapsed ? "Change selection" : "Collapse choices";
        ledgerToggle.setAttribute("aria-expanded", isCollapsed ? "false" : "true");
      }
    }

    function updateLedgerSummary(record) {
      if (!ledgerSummary) return;
      const descriptor = record.status === "Clean"
        ? "clean across all ledgers"
        : record.status.toLowerCase();
      ledgerSummary.textContent =
        `${record.caseId} selected: ${descriptor}. Re-expand to choose another record.`;
    }

    function markControlRun() {
      controlHasRun = true;
      root.classList.add("has-run");
      if (analysis) {
        analysis.hidden = false;
      }
      if (runButton) {
        runButton.textContent = "Re-run Control";
      }
      if (status) {
        status.textContent = `${issueCount} reconciliation issues need PV-owner review. Select a finding to inspect the source evidence.`;
      }
      if (activeRecordId) {
        selectRecord(activeRecordId);
      }
    }

    function selectRecord(caseId) {
      const record = records.get(caseId);
      if (!record) {
        return;
      }

      activeRecordId = caseId;
      const isClean = record.status === "Clean";
      root.querySelectorAll("[data-record-row]").forEach((row) => {
        const isActive = row.getAttribute("data-record-row") === caseId;
        row.classList.toggle("is-active", isActive);
        row.setAttribute("aria-pressed", isActive ? "true" : "false");
        row.querySelectorAll("[data-selected-chip]").forEach((chip) => {
          if (chip instanceof HTMLElement) {
            chip.hidden = !isActive;
          }
        });
      });
      root.querySelectorAll("[data-finding]").forEach((finding) => {
        const isActive = finding.getAttribute("data-finding") === caseId;
        finding.classList.toggle("is-active", isActive);
        finding.setAttribute("aria-pressed", isActive ? "true" : "false");
        finding.querySelectorAll("[data-selected-chip]").forEach((chip) => {
          if (chip instanceof HTMLElement) {
            chip.hidden = !isActive;
          }
        });
      });
      root.querySelectorAll("[data-detail]").forEach((detail) => {
        detail.classList.toggle("is-hidden", detail.getAttribute("data-detail") !== caseId);
      });
      updateSelectionPreview(record);
      if (status) {
        status.textContent = isClean
          ? `${caseId} reconciles cleanly across source, transfer, and acknowledgement. No escalation packet is needed.`
          : `Inspecting ${caseId} across all ledgers. Evidence view, finding card, and packet target are synced.`;
      }
      if (packetButton instanceof HTMLButtonElement) {
        packetButton.hidden = isClean;
        packetButton.disabled = isClean;
      }
      updateLedgerSummary(record);
      setLedgerCollapsed(true);
      if (packet) {
        packet.hidden = true;
      }
    }

    function updateSelectionPreview(record) {
      if (selectedCase) selectedCase.textContent = record.caseId;
      if (selectedFinding) selectedFinding.textContent = record.finding;
      if (selectedStatus) {
        selectedStatus.textContent = record.status === "Clean" ? "Clean record" : record.severity;
        selectedStatus.classList.toggle("is-clean", record.status === "Clean");
      }
      if (selectedSource) selectedSource.textContent = record.sourceReceivedAt;
      if (selectedTransfer) selectedTransfer.textContent = record.transferredAt;
      if (selectedAcknowledgement) selectedAcknowledgement.textContent = record.acknowledgementAt;
      if (selectedSnippet) selectedSnippet.textContent = record.sourceSnippet;
      if (selectedNote) {
        selectedNote.textContent = `Day 0 note: ${record.dayZeroImplication}`;
      }
    }

    function buildPacketText(record) {
      return [
        `Case: ${record.caseId}`,
        `Finding: ${record.finding}`,
        `Acknowledgement status: ${record.acknowledgementStatus}`,
        `Source receipt: ${record.sourceReceivedAt}`,
        `PSP transfer: ${record.transferredAt}`,
        `Acknowledgement: ${record.acknowledgementAt}`,
        "",
        "Source evidence:",
        record.sourceSnippet,
        "",
        "Control note:",
        record.dayZeroImplication,
        "",
        "Requested action:",
        record.escalationSummary,
        "",
        "Boundary: evidence packet only. PV owner confirms validity, duplicate status, clock handling, and reportability.",
      ].join("\n");
    }

    runButton?.addEventListener("click", () => {
      markControlRun();
    });

    root.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.closest('[data-action="toggle-ledgers"]')) return;
      const isCollapsed = ledgerShell?.classList.contains("is-collapsed") ?? false;
      setLedgerCollapsed(!isCollapsed);
    });

    root.querySelectorAll("[data-finding]").forEach((button) => {
      button.addEventListener("click", () => {
        activeRecordId = button.getAttribute("data-finding");
        if (!controlHasRun) {
          markControlRun();
          return;
        }
        selectRecord(activeRecordId);
      });
    });

    root.querySelectorAll("[data-record-row]").forEach((button) => {
      button.addEventListener("click", () => {
        const caseId = button.getAttribute("data-record-row");
        if (records.has(caseId)) {
          activeRecordId = caseId;
          if (!controlHasRun) {
            markControlRun();
            return;
          }
          selectRecord(caseId);
        }
      });
    });

    packetButton?.addEventListener("click", () => {
      if (!controlHasRun) {
        markControlRun();
      }
      const record = records.get(activeRecordId);
      if (record?.status === "Clean") {
        if (status) {
          status.textContent = `${record.caseId} is clean. No escalation packet is needed for that row.`;
        }
        if (packet) {
          packet.hidden = true;
        }
        return;
      }
      if (!record || !packet || !packetOutput) {
        return;
      }
      packetOutput.textContent = buildPacketText(record);
      packet.hidden = false;
      packet.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });
  }
</script>

<style>
  .reconciliation {
    display: grid;
    gap: 1rem;
  }

  .drill-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.2rem;
    align-items: end;
    padding: 4rem 0 2rem;
  }

  .kicker {
    margin: 0;
    color: var(--color-accent);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .drill-hero .kicker {
    grid-column: 1 / -1;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.8rem;
    max-width: 12ch;
    font-size: clamp(3.2rem, 8vw, 6.8rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
  }

  .drill-hero p {
    margin-bottom: 0;
    max-width: 48rem;
    color: var(--color-text-soft);
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .home-link {
    display: inline-flex;
    justify-content: center;
    padding: 0.78rem 1rem;
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
  }

  .control-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem;
  }

  .control-bar p,
  .control-status,
  .packet p {
    margin-bottom: 0;
    color: var(--color-text-soft);
    line-height: 1.65;
  }

  .run-control,
  .change-selection,
  .packet-button {
    border: 0;
    border-radius: 999px;
    background: var(--color-text);
    color: var(--color-inverse);
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    padding: 0.9rem 1.15rem;
    transition: transform 180ms ease, background-color 180ms ease;
  }

  .run-control:hover,
  .run-control:focus-visible,
  .change-selection:hover,
  .change-selection:focus-visible,
  .packet-button:hover,
  .packet-button:focus-visible {
    background: var(--color-accent);
    transform: translateY(-1px);
  }

  .ledger-shell {
    display: grid;
    gap: 0.8rem;
  }

  .ledger-summary-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.15rem;
  }

  .ledger-summary-bar h2 {
    margin: 0.25rem 0 0;
    font-size: 1.12rem;
    line-height: 1.1;
  }

  .ledger-summary-bar p:last-child {
    margin: 0.35rem 0 0;
    color: var(--color-text-soft);
    line-height: 1.55;
  }

  .ledger-body {
    display: grid;
    max-height: 260rem;
    opacity: 1;
    overflow: hidden;
    transform: translateY(0);
    transition:
      max-height 420ms ease,
      opacity 240ms ease,
      transform 320ms ease;
  }

  .ledger-shell.is-collapsed .ledger-body {
    max-height: 0;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-0.35rem);
  }

  .ledger-shell.is-collapsed .ledger-summary-bar {
    border-color: rgba(22, 50, 47, 0.28);
    background: rgba(250, 245, 237, 0.92);
  }

  .ledger-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .ledger,
  .findings,
  .evidence,
  .packet {
    padding: 1.15rem;
  }

  .ledger-head {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.9rem;
  }

  .ledger-head span {
    display: inline-grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .ledger-head h2,
  .panel-title h2 {
    margin-bottom: 0;
    font-size: 1.12rem;
    line-height: 1.1;
  }

  .ledger-list,
  .finding-list {
    display: grid;
    gap: 0.65rem;
  }

  .ledger-row,
  .finding-card {
    display: grid;
    gap: 0.28rem;
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: rgba(250, 245, 237, 0.7);
    color: var(--color-text);
    cursor: pointer;
    font: inherit;
    padding: 0.82rem;
    text-align: left;
  }

  .row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }

  .selected-chip {
    flex: 0 0 auto;
    border: 1px solid rgba(22, 50, 47, 0.28);
    border-radius: 999px;
    background: var(--color-text);
    color: var(--color-inverse);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.12rem 0.42rem;
    text-transform: uppercase;
  }

  .ledger-row.has-finding {
    border-color: rgba(181, 95, 47, 0.34);
    background: rgba(181, 95, 47, 0.08);
  }

  .ledger-row.is-active,
  .finding-card.is-active {
    border-color: var(--color-text);
    background: rgba(22, 50, 47, 0.1);
    box-shadow: inset 5px 0 0 var(--color-accent), 0 10px 24px rgba(22, 50, 47, 0.12);
  }

  .ledger-row.is-active strong,
  .finding-card.is-active strong {
    color: var(--color-text);
  }

  .ledger-row .record-id,
  .finding-card .record-id,
  .evidence-head span,
  .timestamp-grid span,
  .criterion span {
    color: var(--color-text-soft);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ledger-row strong,
  .finding-card strong {
    font-size: 0.96rem;
    line-height: 1.2;
  }

  .ledger-row small,
  .finding-card small,
  .ledger-row em,
  .criterion small {
    color: var(--color-text-soft);
    font-size: 0.84rem;
    font-style: normal;
    line-height: 1.45;
  }

  .selected-record {
    display: grid;
    gap: 1rem;
