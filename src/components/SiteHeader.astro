---
import type { NavLink } from "@/types/content";

interface Props {
  nav: NavLink[];
}

const { nav } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const boundaryText =
  "Static front-end demo using synthetic/redacted examples. It does not submit reports, decide validity, assess seriousness, determine reportability, send messages, or handle real patient data. Qualified PV/Quality owners remain responsible for all safety decisions.";
---

<header class="site-header">
  <div class="page-shell header-grid">
    <a class="brand" href={baseUrl}>
      <span class="brand-mark">SI</span>
      <span class="brand-text">
        <strong>Safety Intake Desk</strong>
        <small>BioScript case-study MVP</small>
      </span>
    </a>
    <nav aria-label="Primary" class="site-nav">
      {nav.map((item) => (
        <a
          aria-current={item.variant === "accent" ? "page" : undefined}
          class:list={[item.variant === "accent" && "nav-accent"]}
          href={item.href}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
  <div class="page-shell compliance-boundary" role="note" aria-label="Demo compliance boundary">
    <strong>Demo boundary</strong>
    <span>{boundaryText}</span>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
    backdrop-filter: blur(14px);
  }

  .header-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-panel-soft);
    box-shadow: 0 8px 24px rgba(24, 42, 39, 0.08);
  }

  .compliance-boundary {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.7rem;
    align-items: start;
    margin-top: 0.55rem;
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-panel-soft);
    box-shadow: 0 8px 24px rgba(24, 42, 39, 0.06);
    color: var(--color-text-soft);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .compliance-boundary strong {
    color: var(--color-text);
    white-space: nowrap;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 16px;
    background: var(--color-text);
    color: var(--color-inverse);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .brand-text {
    display: grid;
    gap: 0.1rem;
  }

  .brand-text strong {
    font-size: 0.98rem;
  }

  .brand-text small {
    color: var(--color-text-soft);
    font-size: 0.78rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 1rem;
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-soft);
    font-size: 0.92rem;
    text-decoration: none;
    transition: background-color 180ms ease, color 180ms ease, transform 180ms ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--color-text);
  }

  .site-nav a.nav-accent {
    margin: -0.4rem 0;
    padding: 0.46rem 0.78rem;
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-weight: 700;
  }

  .site-nav a.nav-accent:hover,
  .site-nav a.nav-accent:focus-visible {
    background: var(--color-accent);
    color: var(--color-inverse);
    transform: translateY(-1px);
  }

  @media (max-width: 820px) {
    .site-header {
      padding-top: 0.75rem;
    }

    .header-grid {
      border-radius: 28px;
      align-items: flex-start;
      flex-direction: column;
    }

    .site-nav {
      justify-content: flex-start;
    }

    .compliance-boundary {
      grid-template-columns: 1fr;
    }
  }
</style>
