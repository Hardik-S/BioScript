---
import type { NavLink } from "@/types/content";

interface Props {
  nav: NavLink[];
}

const { nav } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<header class="site-header">
  <div class="page-shell header-grid">
    <a class="brand" href={baseUrl}>
      <span class="brand-mark">SI</span>
      <span class="brand-text">
        <strong>Safety Intake Desk</strong>
        <small>BioScript case-study MVP</small>
      </span>
    </a>
    <nav aria-label="Primary" class="site-nav">
      {nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0 0;
    backdrop-filter: blur(14px);
  }

  .header-grid {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: rgba(247, 241, 230, 0.82);
    box-shadow: 0 8px 24px rgba(24, 42, 39, 0.08);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 16px;
    background: var(--color-text);
    color: var(--color-inverse);
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .brand-text {
    display: grid;
    gap: 0.1rem;
  }

  .brand-text strong {
    font-size: 0.98rem;
  }

  .brand-text small {
    color: var(--color-text-soft);
    font-size: 0.78rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 1rem;
  }

  .site-nav a {
    color: var(--color-text-soft);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--color-text);
  }

  @media (max-width: 820px) {
    .site-header {
      padding-top: 0.75rem;
    }

    .header-grid {
      border-radius: 28px;
      align-items: flex-start;
      flex-direction: column;
    }

    .site-nav {
      justify-content: flex-start;
    }
  }
</style>
