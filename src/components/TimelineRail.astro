---
import type { TimelineStep } from "@/types/content";

interface Props {
  steps: TimelineStep[];
}

const { steps } = Astro.props;
---

<ol class="timeline">
  {steps.map((step, index) => (
    <li class="timeline-item panel">
      <div class="marker">{String(index + 1).padStart(2, "0")}</div>
      <div>
        <h3>{step.title}</h3>
        <p>{step.detail}</p>
      </div>
    </li>
  ))}
</ol>

<style>
  .timeline {
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.25rem;
  }

  .marker {
    display: inline-grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  h3,
  p {
    margin: 0;
  }

  h3 {
    font-size: 1.08rem;
  }

  p {
    margin-top: 0.55rem;
    color: var(--color-text-soft);
    line-height: 1.7;
  }
</style>
